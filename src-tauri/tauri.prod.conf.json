{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "睿威智测 RAILWISE",
  "identifier": "com.railwiseai.desktop",
  "mainBinaryName": "railwise",
  "bundle": {
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/railwise/32x32.png",
      "icons/railwise/128x128.png",
      "icons/railwise/128x128@2x.png",
      "icons/railwise/icon.icns",
      "icons/railwise/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/railwise/icon.ico",
        "headerImage": "assets/nsis-header-railwise.bmp",
        "sidebarImage": "assets/nsis-sidebar-railwise.bmp",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese"],
        "installMode": "currentUser",
        "startMenuFolder": "RAILWISE"
      }
    },
    "macOS": {
      "entitlements": "./entitlements.plist",
      "dmg": {
        "background": "assets/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 440
        },
        "appPosition": {
          "x": 180,
          "y": 220
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 220
        }
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"],
        "section": "science",
        "files": {
          "/usr/share/metainfo/com.railwiseai.desktop.metainfo.xml": "release/appstream.metainfo.xml"
        }
      },
      "rpm": {
        "compression": {
          "type": "none"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwMTYxMUNEQTM0NkMyOTcKUldTWHdrYWp6UkVXc08rYStqOUJvQVdlV2ZwenlML2FzVlorbm1HdldQa2ZCSUc4MFFlWG9EOWQK",
      "endpoints": ["https://updates.railwise.cn/desktop/{{target}}/{{current_version}}"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
